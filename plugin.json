{
  "name": "msgraph",
  "displayName": "Teams & Outlook",
  "version": "0.5.0",
  "description": "Microsoft Teams chat + Outlook mail via Graph API — read/send/search messages and email with real-time push and AI tooling",
  "icon": {
    "lucide": "message-square-more"
  },
  "author": "Kyle Boyer <https://github.com/KyleBoyer>",
  "permissions": [
    "config:read",
    "config:write",
    "state:publish",
    "events:publish",
    "tools:register",
    "ui:panel",
    "ui:navigation",
    "ui:settings",
    "notifications:send",
    "auth:window",
    "safe-storage",
    "network:fetch",
    "navigation:open"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "preferences": {
        "type": "object",
        "properties": {
          "notifications": {
            "type": "boolean",
            "default": true,
            "description": "Show desktop notifications for new messages while the panel is open"
          },
          "pollIntervalSeconds": {
            "type": "number",
            "default": 30,
            "description": "How often to refresh the chat list in the panel"
          },
          "debugLogging": {
            "type": "boolean",
            "default": false,
            "description": "Write verbose debug logs to ~/.kai/plugin-logs/msgraph/"
          }
        }
      },
      "toolPermissions": {
        "type": "object",
        "description": "Enable/disable individual AI tools",
        "properties": {
          "authStatus": {
            "type": "boolean",
            "default": true
          },
          "findUser": {
            "type": "boolean",
            "default": true
          },
          "listChats": {
            "type": "boolean",
            "default": true
          },
          "getChatMessages": {
            "type": "boolean",
            "default": true
          },
          "searchMessages": {
            "type": "boolean",
            "default": true
          },
          "sendMessage": {
            "type": "boolean",
            "default": true
          },
          "sendDm": {
            "type": "boolean",
            "default": true
          },
          "reactToMessage": {
            "type": "boolean",
            "default": true
          },
          "getTeamsImage": {
            "type": "boolean",
            "default": true
          },
          "getAttachment": {
            "type": "boolean",
            "default": true
          },
          "createGroupChat": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "graphToken": {
        "type": "object",
        "description": "Cached OAuth token set (managed by the plugin)"
      },
      "encryptedCredentials": {
        "type": "object",
        "description": "Encrypted auto-login credentials (managed by the plugin)"
      }
    }
  }
}
